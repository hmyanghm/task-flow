generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  categories           Category[]
  tasks                Task[]
  memos                Memo[]
  events               Event[]
  schedules            Schedule[]
  documents            Document[]
  meetingSlots         MeetingSlot[]
  meetingBookings      MeetingBooking[]
  slackConfigs         SlackConfig[]
  notificationSettings NotificationSetting[]
  focusTimeSettings    FocusTimeSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3B82F6")
  icon      String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  memos     Memo[]
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  status      String     @default("todo") // todo, in_progress, done
  priority    String     @default("medium") // low, medium, high, urgent
  dueDate     DateTime?
  category    Category   @relation(fields: [categoryId], references: [id])
  categoryId  String
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules   Schedule[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([dueDate])
  @@index([userId])
}

model Memo {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  tags       String? // comma-separated tags
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
  @@index([userId])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  location    String?
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean   @default(false)
  color       String?
  type        String    @default("event") // event, focus_time, meeting, reminder
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?
  isRecurring Boolean   @default(false)
  recurrence  String?   // cron expression for recurring events
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startTime, endTime])
  @@index([categoryId])
  @@index([type])
  @@index([userId])
}

model Schedule {
  id           String   @id @default(cuid())
  name         String
  cronExpr     String // cron expression e.g. "0 9 * * *"
  type         String // slack_notify, doc_generate, reminder, focus_time
  targetId     String?
  targetType   String? // task, memo, event
  slackChannel String?
  message      String?  @db.Text
  isActive     Boolean  @default(true)
  task         Task?    @relation(fields: [taskId], references: [id])
  taskId       String?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([userId])
}

model Document {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.LongText
  sourceType String // daily_summary, weekly_report, category_report
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model MeetingSlot {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  duration    Int      @default(30) // minutes
  slots       String   @db.LongText // JSON array of available time slots
  bookingLink String   @unique @default(cuid())
  isActive    Boolean  @default(true)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model MeetingBooking {
  id            String   @id @default(cuid())
  meetingSlotId String
  bookerName    String
  bookerEmail   String
  startTime     DateTime
  endTime       DateTime
  status        String   @default("confirmed") // confirmed, cancelled
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([meetingSlotId])
  @@index([userId])
}

model SlackConfig {
  id             String  @id @default(cuid())
  botToken       String  @db.Text
  defaultChannel String
  isActive       Boolean @default(true)
  userId         String?
  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationSetting {
  id              String  @id @default(cuid())
  type            String // before_event, daily_summary, task_due
  minutesBefore   Int     @default(30)
  slackChannel    String?
  isActive        Boolean @default(true)
  cronExpr        String? // for recurring notifications
  userId          String?
  user            User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FocusTimeSetting {
  id              String  @id @default(cuid())
  minDuration     Int     @default(60) // minimum focus block in minutes
  preferredStart  String  @default("09:00")
  preferredEnd    String  @default("18:00")
  excludeWeekends Boolean @default(true)
  isActive        Boolean @default(true)
  userId          String?
  user            User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
